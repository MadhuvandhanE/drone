# ── JARVIS Hive Backend – Environment Configuration ──────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# Camera source for the vision pipeline.
# 0 = built-in laptop webcam (default during development)
# 1 = first USB / external webcam
# rtsp://192.168.144.108:554/stream=0 = Peeper TX10 / Skydroid TX10 (future)
CAMERA_SOURCE=0

# Host and port for the FastAPI server.
HOST=0.0.0.0
PORT=8000

# Set to "cuda" to force GPU inference, "cpu" to force CPU.
# Leave blank to let the system auto-detect (recommended).
YOLO_DEVICE=

# YOLO model file path (relative to hive_backend/).
# Change to a custom fine-tuned model once available.
YOLO_MODEL=yolov8n.pt
